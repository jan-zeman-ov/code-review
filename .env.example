# Zkopíruj do .env (nikdy necommituj do gitu!)
ANTHROPIC_API_KEY=sk-ant-...
BB_USERNAME=tvuj-bitbucket-username
BB_APP_PASSWORD=...          # Bitbucket: Settings → App passwords → CR: read, PR: read+write, Webhooks: read
JIRA_BASE_URL=https://tvoje-firma.atlassian.net
JIRA_EMAIL=ty@firma.cz
JIRA_API_TOKEN=...           # Jira: account settings → Security → API tokens
WEBHOOK_SECRET=              # volitelné, pro ověření podpisu webhooků
